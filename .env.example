# Telegram Bot API token from @BotFather
TELEGRAM_TOKEN=replace_me

# GigaChat API credentials/token
GIGACHAT_TOKEN=replace_me

# YooKassa credentials
YOOKASSA_SHOP_ID=replace_me
YOOKASSA_SECRET_KEY=replace_me

# Paid analysis price in RUB
PAID_PRICE=1490

# Keep false for current Railway compatibility if certificates are not configured.
# Prefer true after SSL certificates are configured and tested.
GIGACHAT_VERIFY_SSL=false
